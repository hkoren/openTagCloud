{
  "name": "@opentagcloud/angular",
  "version": "0.3.0",
  "description": "Angular adapter for openTagCloud — a dependency-free, self-packing, SSR-friendly tag cloud.",
  "keywords": [
    "angular",
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "component"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
