    "@angular/compiler-cli": "^19.2.0",
    "@angular/core": "^19.2.0",
    "ng-packagr": "^19.2.0",
    "rxjs": "^7.8.1",
    "typescript": "~5.7.2",
    "zone.js": "~0.15.0"
  }
}
