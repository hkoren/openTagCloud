{
  "name": "opentagcloud",
  "version": "0.3.0",
  "description": "A dependency-free, self-packing, SSR-friendly tag cloud component for Svelte 5. Thin adapter over @opentagcloud/core.",
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "component",
    "vanilla",
    "no-build",
    "umd"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkoren/openTagCloud.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/hkoren/openTagCloud/issues"
  },
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "default": "./dist/vanilla.js"
    },
    "./dist/opentagcloud.vanilla.js": "./dist/opentagcloud.vanilla.js"
  },
  "unpkg": "dist/opentagcloud.vanilla.js",
  "jsdelivr": "dist/opentagcloud.vanilla.js",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && svelte-package && node scripts/copy-vanilla-umd.mjs && publint",
    "test": "vitest run",
    "preview": "vite preview",
    "package": "npm run build",
    "prepublishOnly": "npm run build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@opentagcloud/core": "^0.3.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.15.1",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/svelte": "^5.2.4",
    "jsdom": "^26.0.0",
    "publint": "^0.2.12",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  }
}
