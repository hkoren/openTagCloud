{
  "name": "@opentagcloud/solid",
  "version": "0.4.1",
  "description": "SolidJS adapter for openTagCloud — a dependency-free, self-packing, SSR-friendly tag cloud.",
  "keywords": [
    "solid",
    "solidjs",
    "solid-start",
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "component"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkoren/openTagCloud.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/hkoren/openTagCloud/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/source/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source/index.d.ts",
      "solid": "./dist/source/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node scripts/build-compiled.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opentagcloud/core": "^0.4.1"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "babel-preset-solid": "^1.9.0",
    "jsdom": "^26.0.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
