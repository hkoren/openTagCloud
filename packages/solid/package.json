{
  "name": "@opentagcloud/solid",
  "version": "0.3.0",
  "description": "SolidJS adapter for openTagCloud — a dependency-free, self-packing, SSR-friendly tag cloud.",
  "keywords": [
    "solid",
    "solidjs",
    "solid-start",
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "component"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkoren/openTagCloud.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/hkoren/openTagCloud/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opentagcloud/core": "^0.3.0"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.0",
    "typescript": "^5.7.2"
  }
}
