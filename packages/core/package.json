{
  "name": "@opentagcloud/core",
  "version": "0.3.0",
  "description": "Framework-agnostic layout engine, vanilla-JS renderer, and stylesheet for openTagCloud \u2014 a dependency-free, self-packing, SSR-friendly tag cloud.",
  "keywords": [
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "vanilla",
    "framework-agnostic"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkoren/openTagCloud.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/hkoren/openTagCloud/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "default": "./dist/vanilla.js"
    },
    "./styles.css": "./dist/styles.css",
    "./dist/opentagcloud.vanilla.js": "./dist/opentagcloud.vanilla.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "./dist/umd.js",
    "./dist/opentagcloud.vanilla.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/emit-css.mjs && esbuild src/umd.ts --bundle --format=iife --global-name=openTagCloud --outfile=dist/opentagcloud.vanilla.js --banner:js=\"/* openTagCloud \u2014 script-tag build. window.openTagCloud.{mount,defineElement,renderTagCloud,...}; registers <otc-tag-cloud> automatically. Generated from src/umd.ts. */\"",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "unpkg": "dist/opentagcloud.vanilla.js",
  "jsdelivr": "dist/opentagcloud.vanilla.js",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
