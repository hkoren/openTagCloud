{
  "name": "opentagcloud",
  "version": "0.2.0",
  "description": "A dependency-free, self-packing, SSR-friendly tag cloud component for Svelte 5.",
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "tag-cloud",
    "tagcloud",
    "wordcloud",
    "word-cloud",
    "component"
  ],
  "license": "MIT",
  "author": "Henry Koren",
  "homepage": "https://github.com/hkoren/openTagCloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hkoren/openTagCloud.git"
  },
  "bugs": {
    "url": "https://github.com/hkoren/openTagCloud/issues"
  },
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.15.1",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "publint": "^0.2.12",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
